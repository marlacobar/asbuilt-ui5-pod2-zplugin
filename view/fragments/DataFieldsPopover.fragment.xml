<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form">

    <Popover
        id="idDataFieldsPopover"
        title="{i18n>asBuilt.tbl.assyData}"
        showHeader="false"
        afterClose="onPopoverAfterClose"
        placement="VerticalPreferredBottom"
        verticalScrolling="true"
        maxHeight="30rem">

		<layout:VerticalLayout >
			<List 
				id="idDataFieldsList"
				items="{path:'AsBuilt>DATA_FIELDS'}"
				headerText="{i18n>asBuilt.tbl.assyData}"
				includeItemInSelection="false" >
			<CustomListItem type="Inactive" selected="false" >
					<form:SimpleForm>
						<form:content>
							<Label text="{AsBuilt>DATA_FIELD_LABEL}" />
							<Text text="{AsBuilt>DATA_FIELD_VALUE}"/>
						</form:content>
					</form:SimpleForm>
				</CustomListItem>
			</List>
		</layout:VerticalLayout>

    </Popover>
</core:FragmentDefinition>
