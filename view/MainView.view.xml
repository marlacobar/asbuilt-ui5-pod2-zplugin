<mvc:View
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:f="sap.f"
    xmlns:uxap="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:layout="sap.ui.layout"
    controllerName="mhp.pod2.zplugins.AsBuiltReportPlugin.controller.MainView"
    width="100%"
    height="100%" >
    <VBox
        width="100%"
        height="100%"
        fitContainer="true">

        <!-- FilterBar -->
        <fb:FilterBar
            id="idFilterBar"
            showFilterConfiguration="false"
            showRestoreButton="false"
            showClearButton="true"
            showGoOnFB="true"
            search="onSearch" >
            <fb:filterGroupItems>
                <!-- SFC -->
                <fb:FilterGroupItem
                    id="idSfcFI"
                    name="SFC"
                    groupName="AsBuiltGroup"
                    label="{i18n>filterbar.sfc}"
                    mandatory="true"
                    visibleInFilterBar="true" >
                    <fb:control>
                        <Input id="idSfcInput" />
                    </fb:control>
                </fb:FilterGroupItem>

                <!-- Component State -->
                <fb:FilterGroupItem
                    id="idComponentStateFI"
                    name="ComponentState"
                    groupName="AsBuiltGroup"
                    label="{i18n>filterbar.componentState}"
                    visibleInFilterBar="true" >
                    <fb:control>
                        <Select id="idComponentStateSelect">
                            <items>
                                <core:Item key="All" text="{i18n>filterbar.all}" />
                                <core:Item key="Assembled" text="{i18n>filterbar.assembled}" />
                                <core:Item key="Unassembled" text="{i18n>filterbar.unassembled}" />
                                <core:Item key="AssembledUnassembled" text="{i18n>filterbar.assembledUnassembled}" />
                                <core:Item key="Removed" text="{i18n>filterbar.removed}" />
                            </items>
                        </Select>
                    </fb:control>
                </fb:FilterGroupItem>

                <!-- Find Component -->
                <fb:FilterGroupItem
                    id="idComponentFI"
                    name="FindComponent"
                    groupName="AsBuiltGroup"
                    label="{i18n>filterbar.findComponent}"
                    visibleInFilterBar="true" >
                    <fb:control>
                        <Input id="idFindComponentInput" />
                    </fb:control>
                </fb:FilterGroupItem>
            </fb:filterGroupItems>
        </fb:FilterBar>


        <f:FlexibleColumnLayout
            id="fcl"
            layout="OneColumn" >
            <f:layoutData>
                <FlexItemData growFactor="1" />
            </f:layoutData>

            <f:beginColumnPages>
                <mvc:XMLView viewName="mhp.pod2.zplugins.AsBuiltReportPlugin.view.BomComponents" />
            </f:beginColumnPages>

            <f:midColumnPages>
                <mvc:XMLView viewName="mhp.pod2.zplugins.AsBuiltReportPlugin.view.ActualComponents" />
            </f:midColumnPages>
        </f:FlexibleColumnLayout>


    </VBox>
</mvc:View>
